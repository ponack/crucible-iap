{
	# Set email for Let's Encrypt production TLS.
	# Leave blank to use self-signed certs (fine for internal/dev).
	email {$CADDY_ACME_EMAIL}

	# Uncomment to use a custom ACME server (e.g. Step-CA for internal PKI)
	# acme_ca https://ca.internal/acme/acme/directory
}

# ── Main domain ───────────────────────────────────────────────────────────────
{$CRUCIBLE_BASE_URL:https://localhost} {

	# Auth and API → Go backend
	handle /auth/* {
		reverse_proxy crucible-api:8080
	}

	handle /api/* {
		reverse_proxy crucible-api:8080
	}

	# Health check
	handle /health {
		reverse_proxy crucible-api:8080
	}

	# Grafana — proxied internally; /metrics is NOT proxied (scrape-only)
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# Everything else → SvelteKit UI
	handle {
		reverse_proxy crucible-ui:3000
	}

	# Security headers applied to every response.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	# Framing restrictions applied only to non-Grafana routes.
	# Grafana panels are embedded as iframes on /monitoring, so X-Frame-Options
	# and frame-ancestors must not be set on /grafana/* responses — the browser
	# will refuse to render them if those headers are present.
	@notgrafana not path /grafana/*
	header @notgrafana {
		X-Frame-Options "DENY"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
	}

	log {
		output stderr
		format json
		level INFO
	}
}

# ── Authentik (if bundled) ────────────────────────────────────────────────────
# Expose Authentik on a subdomain or port if needed.
