# Crucible IAP — Environment Configuration
# Copy to .env and fill in values before starting

# ── Core ──────────────────────────────────────────────────────────────────────
CRUCIBLE_ENV=production                        # production | development
CRUCIBLE_BASE_URL=https://crucible.example.com
CRUCIBLE_SECRET_KEY=change-me-32-chars-minimum  # used for JWT signing

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crucible
POSTGRES_USER=crucible
POSTGRES_PASSWORD=change-me

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_STATE=crucible-state
MINIO_BUCKET_ARTIFACTS=crucible-artifacts
MINIO_USE_SSL=false

# ── Authentication ────────────────────────────────────────────────────────────
# At least one of OIDC or local auth must be enabled.

# Option A — Local auth (simple email/password, no IdP needed)
LOCAL_AUTH_ENABLED=false
LOCAL_AUTH_EMAIL=admin@example.com
LOCAL_AUTH_PASSWORD=change-me

# Option B — OIDC (Authentik, Keycloak, Google, etc.)
# Authentik (self-hosted) — or replace with any OIDC provider
OIDC_ISSUER_URL=https://authentik.example.com/application/o/crucible/
OIDC_CLIENT_ID=crucible
OIDC_CLIENT_SECRET=change-me
OIDC_REDIRECT_URL=https://crucible.example.com/auth/callback

# ── Runner ────────────────────────────────────────────────────────────────────
RUNNER_DEFAULT_IMAGE=ghcr.io/ponack/crucible-iap-runner:latest
RUNNER_MAX_CONCURRENT=5
RUNNER_JOB_TIMEOUT_MINUTES=60
RUNNER_MEMORY_LIMIT=2g
RUNNER_CPU_LIMIT=1.0

# ── Reverse proxy ────────────────────────────────────────────────────────────
# Bundled Caddy (default): leave CADDY_ACME_EMAIL blank for self-signed,
# set to your email for automatic Let's Encrypt certificates.
CADDY_ACME_EMAIL=

# External reverse proxy: set these to control which host:port the API and UI
# bind to on the Docker host. Defaults bind to localhost only (127.0.0.1).
# Set to 0.0.0.0 to expose on all interfaces (only do this behind a proxy).
#
# docker compose --profile external-proxy up -d
#
CRUCIBLE_API_EXPOSE=127.0.0.1
CRUCIBLE_API_PORT=8080
CRUCIBLE_UI_EXPOSE=127.0.0.1
CRUCIBLE_UI_PORT=3000

# ── Optional: Authentik (bundled IdP) ────────────────────────────────────────
# Activate with: docker compose --profile authentik up -d
AUTHENTIK_SECRET_KEY=change-me-50-chars-minimum
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me
AUTHENTIK_EXPOSE=127.0.0.1
AUTHENTIK_PORT=9000
