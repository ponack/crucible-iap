# Crucible Agent — Environment Configuration
# Copy to .env.agent and fill in the required values before starting.
#
# Deployment options:
#
# A) Standalone on a separate host (recommended for isolation):
#      docker compose -f docker-compose.agent.yml up -d
#
# B) Co-located on the same host as Crucible:
#      docker compose --profile worker-agent up -d crucible-agent
#      (CRUCIBLE_API_URL is overridden automatically to the internal service URL)
#
# Create a worker pool first in the Crucible UI (Worker Pools → New pool)
# to obtain a pool token.

# ── Required ──────────────────────────────────────────────────────────────────

# Public URL of your Crucible instance (no trailing slash).
# Not used when running via the co-located compose profile.
CRUCIBLE_API_URL=https://crucible.example.com

# UUID of your organisation — find it in Settings → General or any stack URL.
CRUCIBLE_ORG_ID=<your-org-uuid>

# Bearer token issued when the pool was created. Shown once; rotate via the
# Worker Pools page if lost.
CRUCIBLE_POOL_TOKEN=<token-from-pool-creation>

# ── Concurrency ───────────────────────────────────────────────────────────────

# Maximum number of runs this agent executes concurrently.
CRUCIBLE_CAPACITY=3

# How often to poll for new work (Go duration string, e.g. 5s, 10s).
# CRUCIBLE_POLL_INTERVAL=5s

# ── Runner ────────────────────────────────────────────────────────────────────
# Override server-side runner defaults if needed. Leave unset to use whatever
# the server embeds in each job spec.

# RUNNER_DEFAULT_IMAGE=ghcr.io/ponack/crucible-iap-runner:latest
# RUNNER_JOB_TIMEOUT_MINUTES=60
# RUNNER_MEMORY_LIMIT=4g
# RUNNER_CPU_LIMIT=1.0

# Docker network for spawned runner containers.
# Leave unset for standalone deployments — runners use the default bridge
# network and reach the Crucible API via CRUCIBLE_API_URL over the internet.
# Set to "crucible-runner" only when using the co-located compose profile.
# RUNNER_NETWORK=crucible-runner
