# Crucible Agent — Environment Configuration
# Copy to .env.agent and fill in values before starting.
#
# Standalone (remote host):
#   docker run --env-file .env.agent \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     ghcr.io/ponack/crucible-agent:latest
#
# Co-located (same host as Crucible, Docker Compose):
#   docker compose --profile worker-agent up -d crucible-agent
#   (CRUCIBLE_API_URL is set automatically to the internal service URL)

# ── Required ──────────────────────────────────────────────────────────────────
# Public URL of your Crucible instance. Not needed when using the compose
# profile — the service hardcodes the internal http://crucible-api:8080 URL.
CRUCIBLE_API_URL=https://crucible.example.com

# UUID of your organisation. Find it in Settings → General or any stack URL.
CRUCIBLE_ORG_ID=<your-org-uuid>

# Bearer token issued when the pool was created. Shown once — rotate via the
# Worker Pools page if lost.
CRUCIBLE_POOL_TOKEN=<token-from-pool-creation>

# ── Concurrency ───────────────────────────────────────────────────────────────
# Maximum number of runs this agent process executes concurrently.
CRUCIBLE_CAPACITY=3

# How often to poll for new work (Go duration string).
CRUCIBLE_POLL_INTERVAL=5s

# ── Runner ────────────────────────────────────────────────────────────────────
# These mirror the server-side runner settings. Leave unset to use the
# server defaults embedded in each job spec.

# RUNNER_DEFAULT_IMAGE=ghcr.io/ponack/crucible-iap-runner:latest
# RUNNER_JOB_TIMEOUT_MINUTES=60
# RUNNER_MEMORY_LIMIT=4g
# RUNNER_CPU_LIMIT=1.0

# Docker network for spawned runner containers. Required when running via
# compose so containers can reach the API for state backend callbacks.
# RUNNER_NETWORK=crucible-runner
